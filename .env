# ─────────────────────────────────────────────────────────
#  🔐  Episode Downloader — secrets
#
#  Fill in your values below.
#  This file is listed in .gitignore and will NEVER be
#  uploaded to GitHub.
# ─────────────────────────────────────────────────────────

# From https://my.telegram.org → API development tools
TELEGRAM_API_ID=32051166
TELEGRAM_API_HASH=44a292c1c101c9a7a85f4794e7c5609f

# The @username of the Telegram search bot
SEARCH_BOT=@ProSearchY7Bot

# ─── Optional settings (safe to leave as defaults) ───────

# How to format the query sent to the bot
# {series} S{season:02d}E{episode:02d}  →  Dark S02E03
QUERY_TEMPLATE={series} S{season:02d}E{episode:02d}

# Folder where episodes are saved
DOWNLOAD_DIR=./downloads

# Seconds to wait for bot to reply before giving up
RESPONSE_TIMEOUT=120

# Seconds to pause between episode downloads
DELAY_BETWEEN_EPISODES=10
